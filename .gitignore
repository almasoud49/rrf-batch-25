# WordPress theme .gitignore

# Ignore all WordPress uploads, cache, logs, etc.
wp-content/uploads/
wp-content/cache/
wp-content/wp-cache-config.php
wp-content/advanced-cache.php

# Ignore environment-specific files
.env
.env.local
.env.development
.env.production

# Ignore IDE files
*.swp
*.swo
*.sublime-project
*.sublime-workspace
.idea/
.vscode/
.cache/

# Ignore OS generated files
.DS_Store
Thumbs.db

# Ignore node_modules (if using npm/yarn)
node_modules/
dist/
build/

# Ignore composer vendor (unless you're bundling dependencies)
vendor/

# Ignore log files
*.log